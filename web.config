<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- URL Rewrite: Tüm istekleri backend'e yönlendir -->
    <rewrite>
      <rules>
        <rule name="Reverse Proxy to Backend" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:10002/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    
    <!-- SSE için KRİTİK: Dynamic compression KAPALI -->
    <urlCompression doStaticCompression="true" doDynamicCompression="false" />
    
    <!-- Cache kontrol -->
    <httpProtocol>
      <customHeaders>
        <add name="Cache-Control" value="no-cache" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
