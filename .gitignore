# .gitignore for ATC Datalink Backend

# Log files
*.log

# Configuration files with sensitive data

# ----------------------------------------------------------------
# Virtual environments (created by install-venv.bat)
# ----------------------------------------------------------------
venv/
.venv/
ENV/
env/
pip-log.txt
pip-delete-this-directory.txt

# ----------------------------------------------------------------
# Python build / cache artifacts
# ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ----------------------------------------------------------------
# IDE
# ----------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ----------------------------------------------------------------
# OS
# ----------------------------------------------------------------
.DS_Store
Thumbs.db
